# BFC Automation — environment template
# Copy to .env and fill in real values. NEVER commit the real .env (see .gitignore).

# n8n
N8N_BASE_URL=https://n8n-production-eaabe.up.railway.app
N8N_API_KEY=your_n8n_api_key_here

# n8n Internal Credential IDs (used when editing workflows via API)
N8N_GMAIL_CREDENTIAL_ID=your_n8n_gmail_credential_id
N8N_SHEETS_CREDENTIAL_ID=your_n8n_sheets_credential_id
N8N_XERO_CREDENTIAL_ID=your_n8n_xero_credential_id

# GoCardless
GC_LIVE_TOKEN=live_your_gocardless_token_here
GC_WEBHOOK_SECRET=your_gocardless_webhook_secret

# Xero
XERO_TENANT_ID=your_xero_tenant_id_here

# Clubworx
CLUBWORX_ACCOUNT_KEY=your_clubworx_account_key_here

# Google Sheets
SHEETS_TRACKER_ID=your_google_sheet_id_here

# Supabase (new — Phase 0)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
