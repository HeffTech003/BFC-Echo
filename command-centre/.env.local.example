# BFC Command Centre — copy to .env.local and fill in. NEVER commit .env.local.
# Values come from your Supabase project (Sydney / ap-southeast-2):
# Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only. NOT used by the app yet (Phase 0 is user-JWT only). n8n sync
# jobs use this key directly against Supabase — keep it out of the frontend.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
