# BFC Command Centre — copy to .env.local and fill in. NEVER commit .env.local.
# Values come from your Supabase project (Sydney / ap-southeast-2):
# Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only. NOT used by the app yet (Phase 0 is user-JWT only). n8n sync
# jobs use this key directly against Supabase — keep it out of the frontend.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Xero — server-side only. Never expose to the browser.
# OAuth2 tokens are stored in Supabase (xero_tokens table) and refreshed per request.
# Initial setup: run Xero OAuth2 flow via n8n or the /sync page.
XERO_CLIENT_ID=your_xero_client_id
XERO_CLIENT_SECRET=your_xero_client_secret
# Xero tenant (organisation) ID — visible in Xero API responses after OAuth
XERO_TENANT_ID=your_xero_tenant_id

# Stripe — server-side only. Never expose secret key to browser.
# Get from Stripe Dashboard → Developers → API keys.
# Use test keys (sk_test_...) until ready for live payments.
STRIPE_SECRET_KEY=sk_test_...your_key_here
STRIPE_WEBHOOK_SECRET=whsec_...your_webhook_secret
# Public key — safe for browser (used in sign-up flow)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...your_key_here

# ── Anthropic Claude (AI Advisor at /advisor) ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...your_key_here

# ── n8n Webhooks ────────────────────────────────────────────────────────────────
# Communications (single message trigger)
N8N_COMMS_WEBHOOK_URL=https://your-n8n-instance.com/webhook/bfc-comms
# Campaign bulk send trigger
N8N_CAMPAIGN_WEBHOOK_URL=https://your-n8n-instance.com/webhook/bfc-campaigns

# n8n webhook secret (sent in X-Webhook-Secret header)
N8N_WEBHOOK_SECRET=your_secret_here

# n8n welcome email sequence trigger
N8N_WELCOME_WEBHOOK_URL=https://your-n8n-instance.com/webhook/bfc-welcome
# n8n lapsed member re-engagement trigger
N8N_REENGAGE_WEBHOOK_URL=https://your-n8n-instance.com/webhook/bfc-reengage
# n8n lead follow-up automation trigger
N8N_LEAD_FOLLOWUP_WEBHOOK_URL=https://your-n8n-instance.com/webhook/bfc-lead-followup

# ── App URL (used for internal API calls and redirects) ────────────────────────
NEXT_PUBLIC_APP_URL=https://bfc-echo.vercel.app

# ── GoCardless (legacy direct debit) ──────────────────────────────────────────
GOCARDLESS_ACCESS_TOKEN=your_gocardless_access_token
GOCARDLESS_ENV=live  # or "sandbox" for testing

# ── Stripe Price IDs (from Stripe Dashboard → Products) ───────────────────────
STRIPE_PRICE_CASUAL=price_...
STRIPE_PRICE_GYM_MONTHLY=price_...
STRIPE_PRICE_NAC_MONTHLY=price_...
STRIPE_PRICE_ONLINE=price_...
