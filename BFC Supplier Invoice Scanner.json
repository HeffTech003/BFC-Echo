      "name": "Read Attachment"
    },
    {
      "parameters": {
        "jsCode": "// Combine the email + extracted attachment text into an OpenAI request body\nconst email = $('Search Invoice Emails').item.json;\nconst att = $json;\nconst attText = (typeof att === 'object') ? JSON.stringify(att).slice(0, 6000) : String(att).slice(0, 6000);\n\nconst system = \"You extract structured data from a supplier invoice for Bendigo Fight Centre. \"\n  + \"Return JSON only with keys: supplier, amount, currency, gst, due_date, invoice_number, \"\n  + \"description, confidence (high|medium|low), reason_if_unsure. Never invent an amount - leave \"\n  + \"it blank if not clearly stated. If the text is empty/unreadable or it is clearly not an \"\n  + \"invoice, set confidence to low.\";\n\nconst user = `EMAIL FROM: ${email.From || email.from || ''}\\n`\n  + `SUBJECT: ${email.Subject || email.subject || ''}\\n`\n  + `DATE: ${email.date || ''}\\n\\nATTACHMENT / EMAIL TEXT:\\n${attText}`;\n\nconst body = JSON.stringify({\n  model: \"gpt-4o\",\n  temperature: 0,\n  response_format: { type: \"json_object\" },\n  messages: [ { role: \"system\", content: system }, { role: \"user\", content: user } ]\n});\n\nreturn [{ json: {\n  openai_body: body,\n  email_id: email.id,\n  email_from: email.From || email.from || '',\n  email_subject: email.Subject || email.subject || '',\n  email_date: email.date || ''\n}}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        660,
        0
      ],
      "id": "b2947d72-4269-4eef-a378-bba6641a1e77",
      "name": "Build Extraction Input"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "openAiApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json.openai_body }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        880,
        0
      ],
      "id": "4d7a0050-647d-4094-8f18-873c08cde794",
      "name": "Extract Invoice Fields (OpenAI)",
      "credentials": {
        "openAiApi": {
          "id": "45q4b7TL1FhrfMl9",
          "name": "OpenAI account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Parse the AI JSON and map to BFC Transaction Tracker fields\nconst res = $json;\nlet content = '';\ntry { content = res.choices[0].message.content; } catch (e) {}\nlet p = {};\ntry { p = JSON.parse(content); } catch (e) { p = { confidence: 'low', reason_if_unsure: 'Could not parse AI response' }; }\n\nconst ctx = $('Build Extraction Input').item.json;\nconst amount = (p.amount || '').toString().trim();\nconst conf = (p.confidence || 'low').toString().toLowerCase();\nconst needs_review = (conf === 'low') || !amount;\nconst supplier = (p.supplier || '').toString().trim() || ctx.email_from;\n\nconst evidence = `Invoice from ${supplier} for ${amount || '(amount unreadable)'}`\n  + (p.due_date ? `, due ${p.due_date}` : '')\n  + `. Email subject: ${ctx.email_subject}.`\n  + (p.reason_if_unsure ? ` Note: ${p.reason_if_unsure}` : '');\n\nreturn [{ json: {\n  transaction_type: 'supplier invoice',\n  direction: 'money out',\n  supplier_or_customer: supplier,\n  amount: amount,\n  due_date: p.due_date || '',\n  invoice_or_reference: p.invoice_number || '',\n  source_system: 'Gmail / Supplier Invoice Scanner',\n  evidence_summary: evidence,\n  xero_match: 'not checked',\n  attachment_status: needs_review ? 'no readable text / uncertain' : 'read',\n  ai_payment_status: 'invoice received; payment not confirmed',\n  human_payment_status: 'not confirmed',\n  confirmed_by: '',\n  confirmed_date: '',\n  risk_level: needs_review ? 'medium' : 'low',\n  recommended_next_action: needs_review\n    ? 'BFC Team to manually open the invoice email, confirm the amount, then schedule/confirm payment.'\n    : 'BFC Team to verify invoice and schedule/confirm payment.',\n  tracker_status: 'Pending Review',\n  notes: `AI confidence: ${conf}.` + (p.gst ? ` GST: ${p.gst}.` : '') + (p.description ? ` ${p.description}` : ''),\n  source_id_or_link: `https://mail.google.com/mail/u/0/#all/${ctx.email_id}`,\n  email_id: ctx.email_id,\n  needs_review: needs_review,\n  _digest_supplier: supplier,\n  _digest_amount: amount || '(unreadable)',\n  _digest_due: p.due_date || '',\n  _digest_status: needs_review ? 'Pending Review - needs manual read' : 'Pending Review'\n}}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
