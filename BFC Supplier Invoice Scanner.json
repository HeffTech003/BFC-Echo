    {
      "parameters": {
        "jsCode": "const rows = $json.data || [];\nconst today = new Date().toLocaleDateString('en-AU');\nconst lines = rows.map(r =>\n  `- ${r._digest_supplier} — ${r._digest_amount}` +\n  (r._digest_due ? ` (due ${r._digest_due})` : '') +\n  ` [${r._digest_status}]`\n);\nconst body =\n  `BFC Supplier Invoice Scan — ${today}\\n\\n` +\n  `${rows.length} invoice(s) recorded to the Transaction Tracker with status \"Pending Review\":\\n\\n` +\n  `${lines.join('\\n')}\\n\\n` +\n  `Please review and confirm each one before paying, in the BFC Transaction Tracker sheet.\\n` +\n  `(Auto-generated by the Supplier Invoice Scanner.)`;\nreturn [{ json: { subject: `BFC: ${rows.length} supplier invoice(s) scanned (${today})`, body } }];"
      },
      "type": "n8n-nodes-base.code",
