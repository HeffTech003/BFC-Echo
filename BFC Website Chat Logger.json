    {
      "parameters": {
        "jsCode": "// BFC Website Chat Logger — normalise incoming chat details\n// Tuned for the custom BFC website chat widget:\n//   { conversation_id, status, data:{firstName,lastName,email}, history:[{role,content}], page_url }\n// but stays flexible for other field names too.\n\nconst inc = ($json.body && typeof $json.body === 'object') ? $json.body : $json;\nconst data = (inc.data && typeof inc.data === 'object') ? inc.data : {};\n\nfunction pick(...keys) {\n  for (const k of keys) {\n    const v = inc[k];\n    if (v !== undefined && v !== null && String(v).trim() !== '') return String(v).trim();\n  }\n  return '';\n}\n\n// Build a transcript from history[] (or messages[])\nlet transcript = pick('transcript', 'conversation', 'chat');\nconst hist = inc.history || inc.messages;\nif (!transcript && Array.isArray(hist)) {\n  transcript = hist\n    .map(m => `${m.role || m.sender || m.from || ''}: ${m.content || m.text || m.message || ''}`.trim())\n    .join('\\n');\n}\n\nconst status = pick('status'); // e.g. \"trial_requested\"\n\n// Contact details — prefer the structured data{} the AI returns\nlet name = pick('name', 'visitor_name', 'full_name', 'contact_name');\nif (!name) {\n  const fn = (data.firstName || '').trim();\n  const ln = (data.lastName || '').trim();\n  name = [fn, ln].filter(Boolean).join(' ');\n}\nlet email = pick('email', 'visitor_email', 'contact_email') || (data.email || '').trim();\nlet phone = pick('phone', 'visitor_phone', 'contact_phone', 'mobile') || (data.phone || '').trim();\n\n// Fallback: scrape contact details out of the transcript / raw payload\nconst blob = [transcript, JSON.stringify(inc)].join(' ');\nif (!email) { const m = blob.match(/[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}/); if (m) email = m[0]; }\nif (!phone) { const m = blob.match(/(\\+?\\d[\\d ()\\-]{7,}\\d)/); if (m) phone = m[0].trim(); }\n\nconst isTrial = status === 'trial_requested';\n\nconst topic = pick('topic', 'enquiry_topic', 'intent', 'subject', 'category')\n              || (isTrial ? 'Free trial request' : '');\nconst summary = pick('summary', 'enquiry_summary', 'message', 'question', 'last_message')\n                || transcript.slice(0, 800);\n\nlet isLead = pick('is_lead', 'lead');\nif (!isLead) isLead = (isTrial || email || phone) ? 'Yes' : 'No';\n\nconst urgency = pick('urgency', 'priority') || (isTrial ? 'High' : 'Normal');\nconst nextAction = pick('recommended_next_action', 'next_action', 'action')\n  || (isTrial ? 'Contact visitor to book / confirm free trial'\n     : (email || phone) ? 'Follow up with visitor'\n     : 'Review chat — no contact details captured');\n\nreturn [{\n  json: {\n    conversation_id: pick('conversation_id', 'session_id', 'chat_id', 'id'),\n    visitor_name: name,\n    email,\n    phone,\n    enquiry_topic: topic,\n    enquiry_summary: summary,\n    is_lead: isLead,\n    urgency,\n    recommended_next_action: nextAction,\n    page_url: pick('page_url', 'url', 'page', 'source_url'),\n    chatbot_source: pick('chatbot', 'source', 'widget', 'bot_name') || 'BFC Website Chatbot',\n    bot_status: status,\n    status: 'New'\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
