      "id": "3d676119-09d5-431e-b0fa-9e876ada2599",
      "name": "Extract Cancellation (OpenAI)",
      "credentials": {
        "openAiApi": {
          "id": "rROXPicnh1YSebL8",
          "name": "OpenAI account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "let p = {};\ntry { p = JSON.parse($json.choices[0].message.content); } catch (e) { p = { is_cancellation: false, confidence: 'low' }; }\nconst ctx = $('Build Email Extraction Input').item.json;\nconst comments = [p.summary || '', `AI confidence: ${p.confidence || 'low'}.`, `Email: https://mail.google.com/mail/u/0/#all/${ctx.email_id}`].filter(Boolean).join(' ');\nreturn [{ json: {\n  is_cancellation: p.is_cancellation === true,\n  source: 'Email',\n  name: p.name || '',\n  email: p.email || ctx.email_from || '',\n  phone: p.phone || '',\n  membership_type: p.membership_type || '',\n  reason: p.reason || '',\n  last_training_date: p.last_training_date || '',\n  comments: comments,\n  email_id: ctx.email_id\n} }];"
      },
