    {
      "parameters": {
        "jsCode": "const m = $json;\nconst text = (m.text || m.snippet || '').slice(0, 6000);\nconst system = \"You review an email received by Bendigo Fight Centre and decide whether it is a genuine membership cancellation request. Return JSON only with keys: is_cancellation (true/false), name, email, phone, membership_type (one of: Casual, Monthly Direct Debit, 3-Month, 6-Month, Annual, Youth/Junior, Family, Trial (not yet converted), or empty), reason (one of: cost, moving away, injury, work/schedule, switching gyms, personal reasons, other, or empty), last_training_date, summary, confidence (high|medium|low). Never invent details - leave fields blank if not stated. Marketing emails, member newsletters, and unrelated mail are is_cancellation: false.\";\nconst user = `EMAIL FROM: ${m.from?.text || m.From || ''}\\nSUBJECT: ${m.subject || m.Subject || ''}\\n\\nBODY:\\n${text}`;\nreturn [{ json: {\n  openai_body: JSON.stringify({ model: 'gpt-4o', temperature: 0, response_format: { type: 'json_object' }, messages: [ { role: 'system', content: system }, { role: 'user', content: user } ] }),\n  email_id: m.id,\n  email_from: m.from?.text || m.From || '',\n  email_subject: m.subject || m.Subject || ''\n} }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        600,
        300
      ],
      "id": "0f74535c-b031-4ddc-99d0-9772920be850",
      "name": "Build Email Extraction Input"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "openAiApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json.openai_body }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
